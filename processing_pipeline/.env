# Copier en .env et adapter avant docker compose up

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=eu-west-1
S3_BUCKET=ott-bucket
OTT_LOG_LEVEL=debug
REDIS_URL=redis://redis:6379

ORCHESTRATOR_URL=http://media-orchestrator:8000


MULTIPART_THRESHOLD=104857600
CHUNK_SIZE=8388608
MAX_RETRIES=3
RETRY_DELAY=1.0

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
